#!/usr/bin/env bash

set -e

# Get staged files
git diff --cached --name-only --diff-filter=ACM | while read -r file; do
    [ -f "$file" ] || continue
    [ -s "$file" ] || continue

    # Skip binaries
    if git diff --numstat -- "$file" | grep -q '^-'; then
        continue
    fi

    # Work on a temp copy to avoid touching index-first
    tmp="$(mktemp)"

    cp "$file" "$tmp"

    # Remove trailing whitespace (GNU + BSD compatible)
    if sed --version >/dev/null 2>&1; then
        sed -i 's/[[:space:]]\+$//' "$tmp"
    else
        sed -i '' -E 's/[[:space:]]+$//' "$tmp"
    fi

    # Ensure trailing newline
    if [ -n "$(tail -c 1 "$tmp")" ]; then
        printf '\n' >> "$tmp"
    fi

    # Only update working tree file
    mv "$tmp" "$file"

    # ❌ IMPORTANT: DO NOT re-add file
    # git add "$file"   <-- removed intentionally

done
