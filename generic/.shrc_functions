_worktree_add_for_branch() {
    BRANCH_NAME="$1"
    FOLDER="$2"
    if git show-ref --verify --quiet "refs/heads/${BRANCH_NAME}"; then
        echo "Branch ${BRANCH_NAME} exists locally, creating worktree on it"
        git worktree add "${FOLDER}" "${BRANCH_NAME}"
    elif git show-ref --verify --quiet "refs/remotes/origin/${BRANCH_NAME}"; then
        echo "Branch ${BRANCH_NAME} exists on origin, creating local tracking branch"
        git worktree add -b "${BRANCH_NAME}" --track "${FOLDER}" "origin/${BRANCH_NAME}"
    else
        echo "Branch ${BRANCH_NAME} does not exist anywhere, creating it from HEAD"
        git worktree add -b "${BRANCH_NAME}" "${FOLDER}"
    fi
    echo "Created worktree @ ${FOLDER}"
}

worktree-create() {
    if [ $# -lt 1 ]; then
        echo "Usage: $0 BRANCH_NAME"
        echo "  Fetches origin first, then:"
        echo "    - if BRANCH_NAME exists locally, creates a worktree on it"
        echo "    - else if origin/BRANCH_NAME exists, creates a local tracking branch from it"
        echo "    - otherwise, creates a new branch from HEAD"
        return 1
    fi
    BRANCH_NAME="$1"
    BRANCH_SLUG=$(echo "$BRANCH_NAME" | tr '[:upper:]' '[:lower:]' | sed -E 's/[^a-z0-9]+/-/g; s/^-//; s/-$//')
