function review-pr() {
    SELECTED_PR=$(gh pr list --json number,title,headRefName --template '{{range .}}{{.number}}{{"\t"}}{{.title}}{{"\t"}}{{.headRefName}}{{"\n"}}{{end}}' | fzf)
    if [ -z "$SELECTED_PR" ]; then
        echo "You didn't select a PR number, will do nothing"
        exit 1
    fi
    PR_NUMBER=$(echo "$SELECTED_PR" | cut -f1)
    PR_BRANCH=$(echo "$SELECTED_PR" | cut -f3)
    PR_BRANCH_SLUG=$(echo "$PR_BRANCH" | tr '[:upper:]' '[:lower:]' | sed -E 's/[^a-z0-9]+/-/g; s/^-//; s/-$//')
    echo "You selected PR: $PR_NUMBER (branch: $PR_BRANCH)"
    CURRENT_PROJECT="$(basename $(pwd))"
    echo "Current project is: ${CURRENT_PROJECT}"
    BRANCH_TO_REVIEW="pull/${PR_NUMBER}/head"
    LOCAL_BRANCH_NAME="PR-${PR_NUMBER}-${PR_BRANCH_SLUG}-$(date +%Y-%m-%d-%H%M)"
    echo "Branch to review is: $BRANCH_TO_REVIEW"
    echo "Will fetch PR remote branch, and create a local PR branch with name: $LOCAL_BRANCH_NAME"
    git fetch origin "$BRANCH_TO_REVIEW:$LOCAL_BRANCH_NAME"
    NEW_FOLDER_NAME="${WORKTREES_FOLDER}/${CURRENT_PROJECT}-PR-${PR_NUMBER}-${PR_BRANCH_SLUG}-$(date +%Y-%m-%d-%H%M)"
    _worktree_add_for_branch "${LOCAL_BRANCH_NAME}" "${NEW_FOLDER_NAME}"
    if [ $# -eq 1 ]; then
        if [ "$1" = "-i" ]; then
            USE_INTELLIJ="YES"
        fi
    fi
    if [ -z "$USE_INTELLIJ" ]; then
        echo "Want to open intellij for that PR?"
        sleep 2
        USE_INTELLIJ=$(echo "YES\nNO" | fzf)
    fi
    if [ "$USE_INTELLIJ" = "YES" ]; then
        idea ${NEW_FOLDER_NAME}
    fi
}


function worktree-delete() {
    local WORKTREE FULLPATH BRANCH
    WORKTREE=$(git worktree list | sed '1d' | awk '{
      n=split($1, parts, "/");
      printf "%s %s\t%s\n", parts[n], $3, $1
    }' | fzf \
      --height=40% --reverse --border \
      --prompt="Delete worktree > " \
      --header="Pick a worktree to remove (Esc to cancel)" \
      --with-nth=1 \
      --delimiter=$'\t') || return 1

    [ -z "$WORKTREE" ] && return 1

    FULLPATH=$(echo "$WORKTREE" | cut -f2)
    BRANCH=$(echo "$WORKTREE" | cut -f1 | awk '{print $NF}' | tr -d '[]')

    printf "Remove worktree %s (BRANCH %s)? [y/N] " "$FULLPATH" "$BRANCH"
    read -r confirm
    case "$confirm" in
      [yY]|[yY][eE][sS])
        git worktree remove "$FULLPATH" && echo "Removed $FULLPATH"
        ;;
      *)
        echo "Cancelled"
        ;;
    esac
  }
